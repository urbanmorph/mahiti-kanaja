---
import '../styles/global.css';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
}

const {
  title,
  description = 'Mahiti Kanaja — Karnataka\'s unified public information portal for transparent access to government services, data, and citizen resources.',
  currentPage = '',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#C41E3A" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title} | ಮಾಹಿತಿ ಕಣಜ</title>
  </head>
  <body>
    <TopBar />
    <Header currentPage={currentPage} />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // Scroll-triggered fade-in
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

      // Language toggle
      const langBtns = document.querySelectorAll('.lang-toggle button');
      const savedLang = localStorage.getItem('mk-lang') || 'en';

      function setLang(lang) {
        document.querySelectorAll('[data-en][data-kn]').forEach(el => {
          el.textContent = el.dataset[lang];
        });
        langBtns.forEach(b => {
          b.classList.toggle('active', b.dataset.lang === lang);
        });
        localStorage.setItem('mk-lang', lang);
        document.documentElement.lang = lang === 'kn' ? 'kn' : 'en';
      }

      setLang(savedLang);
      langBtns.forEach(btn => {
        btn.addEventListener('click', () => setLang(btn.dataset.lang));
      });

      // Font size
      let fontSize = parseInt(localStorage.getItem('mk-fs') || '16');
      document.documentElement.style.fontSize = fontSize + 'px';
      document.getElementById('font-decrease')?.addEventListener('click', () => {
        if (fontSize > 13) { fontSize--; document.documentElement.style.fontSize = fontSize + 'px'; localStorage.setItem('mk-fs', String(fontSize)); }
      });
      document.getElementById('font-increase')?.addEventListener('click', () => {
        if (fontSize < 22) { fontSize++; document.documentElement.style.fontSize = fontSize + 'px'; localStorage.setItem('mk-fs', String(fontSize)); }
      });
      document.getElementById('contrast-toggle')?.addEventListener('click', () => {
        document.body.classList.toggle('high-contrast');
      });
    </script>
  </body>
</html>
