---
import Base from '../../layouts/Base.astro';
import spending from '../../../data/spending.json';

const { district_allocation, pension_disbursement, infrastructure_projects, top_schemes } = spending;

// Calculate max allocated value for bar scaling
const maxAllocated = Math.max(...district_allocation.map((d) => d.allocated));

// Pension donut calculations (circumference = 2 * PI * 45 ≈ 282.74)
const circumference = 2 * Math.PI * 45;
const pensionTotal = pension_disbursement.total_cr;
const pensionColors = ['#C41E3A', '#2563EB', '#FFD700', '#0D9F6E'];
let pensionOffset = 0;
const pensionArcs = pension_disbursement.breakdown.map((item, i) => {
  const pct = item.amount_cr / pensionTotal;
  const dashLength = pct * circumference;
  const arc = { ...item, color: pensionColors[i], dashArray: `${dashLength} ${circumference}`, dashOffset: -pensionOffset };
  pensionOffset += dashLength;
  return arc;
});

// Infrastructure totals
const infraTotal = infrastructure_projects.completed + infrastructure_projects.in_progress + infrastructure_projects.planned;
---

<Base title="Public Spending Dashboard" currentPage="dashboard">
  <!-- Header -->
  <section class="hero-section">
    <div class="container">
      <div class="fade-up text-center hero-inner">
        <h1 class="hero-title" data-en="Public Spending Dashboard" data-kn="ಸಾರ್ವಜನಿಕ ವೆಚ್ಚ ಡ್ಯಾಶ್‌ಬೋರ್ಡ್">Public Spending Dashboard</h1>
        <p class="hero-subtitle" data-en="Transparent, real-time data on how public funds are allocated and spent across Karnataka's 31 districts." data-kn="ಕರ್ನಾಟಕದ 31 ಜಿಲ್ಲೆಗಳಲ್ಲಿ ಸಾರ್ವಜನಿಕ ನಿಧಿಗಳನ್ನು ಹೇಗೆ ಹಂಚಿಕೆ ಮಾಡಲಾಗಿದೆ ಮತ್ತು ಖರ್ಚು ಮಾಡಲಾಗಿದೆ ಎಂಬ ಪಾರದರ್ಶಕ, ನೈಜ-ಸಮಯದ ಡೇಟಾ.">
          Transparent, real-time data on how public funds are allocated and spent across Karnataka's 31 districts.
        </p>
        <p class="hero-meta">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          Data last updated: March 20, 2026
        </p>
      </div>
    </div>
  </section>

  <!-- Section 1: District-wise Fund Allocation -->
  <section class="content-section">
    <div class="container dashboard-container">
      <div class="fade-up dashboard-card">
        <div class="card-header">
          <h2 class="card-heading">District-wise Fund Allocation</h2>
          <p class="card-subtext">All values in &#8377; Crores</p>
        </div>

        <!-- Legend -->
        <div class="legend">
          <div class="legend-item">
            <span class="legend-swatch swatch-red"></span>
            <span class="legend-label">Allocated</span>
          </div>
          <div class="legend-item">
            <span class="legend-swatch swatch-blue"></span>
            <span class="legend-label">Released</span>
          </div>
          <div class="legend-item">
            <span class="legend-swatch swatch-green"></span>
            <span class="legend-label">Utilized</span>
          </div>
        </div>

        <!-- Horizontal Grouped Bar Chart -->
        <div class="bar-chart">
          {district_allocation.map((d) => {
            const allocPct = (d.allocated / maxAllocated) * 100;
            const relPct = (d.released / maxAllocated) * 100;
            const utilPct = (d.utilized / maxAllocated) * 100;
            return (
              <div class="bar-row">
                <div class="bar-row-header">
                  <span class="bar-district">{d.district}</span>
                  <div class="bar-values">
                    <span>A: &#8377;{d.allocated.toLocaleString()}</span>
                    <span>R: &#8377;{d.released.toLocaleString()}</span>
                    <span>U: &#8377;{d.utilized.toLocaleString()}</span>
                  </div>
                </div>
                <div class="bar-tracks">
                  <div class="bar-track">
                    <div class="bar-fill bar-red" style={`width: ${allocPct}%`}></div>
                  </div>
                  <div class="bar-track">
                    <div class="bar-fill bar-blue" style={`width: ${relPct}%`}></div>
                  </div>
                  <div class="bar-track">
                    <div class="bar-fill bar-green" style={`width: ${utilPct}%`}></div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: Pension Disbursements -->
  <section class="content-section-alt">
    <div class="container dashboard-container">
      <div class="fade-up dashboard-card">
        <h2 class="card-heading">Pension Disbursements</h2>
        <p class="card-subtext pension-quarter">{pension_disbursement.quarter}</p>

        <div class="pension-layout">
          <!-- Donut Chart -->
          <div class="donut-wrap">
            <svg viewBox="0 0 120 120" width="224" height="224" class="donut-svg">
              {pensionArcs.map((arc) => (
                <circle
                  cx="60" cy="60" r="45"
                  fill="none"
                  stroke={arc.color}
                  stroke-width="14"
                  stroke-dasharray={arc.dashArray}
                  stroke-dashoffset={arc.dashOffset}
                  class="transition-all duration-700"
                />
              ))}
            </svg>
            <div class="donut-center">
              <span class="donut-total">&#8377;{pensionTotal} Cr</span>
              <span class="donut-label">Total</span>
            </div>
          </div>

          <!-- Legend -->
          <div class="pension-legend">
            {pension_disbursement.breakdown.map((item, i) => {
              const pct = ((item.amount_cr / pensionTotal) * 100).toFixed(1);
              return (
                <div class="pension-legend-row">
                  <span class="pension-dot" style={`background: ${pensionColors[i]}`}></span>
                  <span class="pension-type">{item.type}</span>
                  <span class="pension-amount">&#8377;{item.amount_cr} Cr</span>
                  <span class="pension-pct">({pct}%)</span>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 3: Infrastructure Projects -->
  <section class="content-section">
    <div class="container dashboard-container">
      <div class="fade-up dashboard-card">
        <h2 class="card-heading">Infrastructure Projects</h2>
        <p class="card-subtext infra-year">{infrastructure_projects.financial_year}</p>

        <!-- Status cards -->
        <div class="infra-stats">
          <div class="stat-card stat-green">
            <div class="stat-number stat-number-green">{infrastructure_projects.completed.toLocaleString()}</div>
            <div class="stat-label stat-label-green">Completed</div>
            <div class="stat-pct stat-pct-green">
              {((infrastructure_projects.completed / infraTotal) * 100).toFixed(1)}% of total
            </div>
          </div>
          <div class="stat-card stat-blue">
            <div class="stat-number stat-number-blue">{infrastructure_projects.in_progress.toLocaleString()}</div>
            <div class="stat-label stat-label-blue">In Progress</div>
            <div class="stat-pct stat-pct-blue">
              {((infrastructure_projects.in_progress / infraTotal) * 100).toFixed(1)}% of total
            </div>
          </div>
          <div class="stat-card stat-neutral">
            <div class="stat-number stat-number-neutral">{infrastructure_projects.planned.toLocaleString()}</div>
            <div class="stat-label stat-label-neutral">Planned</div>
            <div class="stat-pct stat-pct-neutral">
              {((infrastructure_projects.planned / infraTotal) * 100).toFixed(1)}% of total
            </div>
          </div>
        </div>

        <!-- Breakdown description -->
        <div class="breakdown-box">
          <h3 class="breakdown-title">Project Breakdown</h3>
          <div class="breakdown-grid">
            <div>
              <p class="breakdown-heading">Completed Projects</p>
              <p class="breakdown-text">{infrastructure_projects.completed.toLocaleString()} projects have been finished and handed over. These include roads, bridges, school buildings, and water supply infrastructure across all 31 districts.</p>
            </div>
            <div>
              <p class="breakdown-heading">In-Progress Projects</p>
              <p class="breakdown-text">{infrastructure_projects.in_progress.toLocaleString()} projects are currently under construction or in various stages of execution, with regular monitoring for timely completion.</p>
            </div>
            <div>
              <p class="breakdown-heading">Planned Projects</p>
              <p class="breakdown-text">{infrastructure_projects.planned.toLocaleString()} projects are approved and scheduled for the remainder of {infrastructure_projects.financial_year}, with tenders and procurement underway.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4: Top Schemes by Beneficiaries -->
  <section class="content-section-alt">
    <div class="container dashboard-container">
      <div class="fade-up dashboard-card">
        <h2 class="card-heading schemes-heading">Top Schemes by Beneficiaries</h2>

        <div class="table-wrap">
          <table class="schemes-table">
            <thead>
              <tr>
                <th>#</th>
                <th>Scheme</th>
                <th class="text-right">Beneficiaries</th>
              </tr>
            </thead>
            <tbody>
              {top_schemes.map((scheme, i) => {
                const dotColors = ['var(--color-red)', 'var(--color-blue)', 'var(--color-gold-muted)', 'var(--color-green)'];
                return (
                  <tr>
                    <td>
                      <div class="rank-dot" style={`background: ${dotColors[i]}`}>
                        <span>{i + 1}</span>
                      </div>
                    </td>
                    <td>
                      <span class="scheme-name">{scheme.name}</span>
                    </td>
                    <td class="text-right">
                      <span class="scheme-value">{scheme.beneficiaries_lakh} Lakh</span>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* ── Hero ── */
  .hero-section {
    padding: 72px 0;
    background: var(--color-surface-cool);
  }
  .hero-inner {
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-ink);
    letter-spacing: -0.02em;
  }
  .hero-subtitle {
    margin-top: 16px;
    font-size: 1.125rem;
    color: var(--color-ink-muted);
    line-height: 1.6;
  }
  .hero-meta {
    margin-top: 12px;
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .hero-meta svg {
    vertical-align: middle;
  }

  /* ── Sections ── */
  .content-section {
    padding: 48px 0;
    background: var(--color-surface);
  }
  .content-section-alt {
    padding: 48px 0;
    background: var(--color-surface-cool);
  }
  .dashboard-container {
    max-width: 960px;
  }

  /* ── Dashboard Card ── */
  .dashboard-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: 10px;
    padding: 28px;
  }

  .card-header {
    display: flex;
    flex-direction: column;
    margin-bottom: 32px;
  }
  .card-heading {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-ink);
  }
  .card-subtext {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    margin-top: 4px;
  }
  .pension-quarter { margin-bottom: 32px; }
  .infra-year { margin-bottom: 32px; }
  .schemes-heading { margin-bottom: 32px; }

  /* ── Legend ── */
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    margin-bottom: 32px;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .legend-swatch {
    width: 16px;
    height: 12px;
    border-radius: 2px;
  }
  .swatch-red { background: var(--color-red); }
  .swatch-blue { background: var(--color-blue); }
  .swatch-green { background: var(--color-green); }
  .legend-label {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
  }

  /* ── Bar Chart ── */
  .bar-chart {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .bar-row-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }
  .bar-district {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink);
    width: 160px;
    flex-shrink: 0;
  }
  .bar-values {
    display: flex;
    gap: 12px;
    font-size: 0.75rem;
    color: var(--color-ink-muted);
    text-align: right;
  }
  .bar-tracks {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .bar-track {
    height: 12px;
    width: 100%;
    background: var(--color-surface-cool);
    border-radius: 9999px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    border-radius: 9999px;
    transition: width 0.7s;
  }
  .bar-red { background: var(--color-red); }
  .bar-blue { background: var(--color-blue); }
  .bar-green { background: var(--color-green); }

  /* ── Pension ── */
  .pension-layout {
    display: flex;
    align-items: center;
    gap: 40px;
  }
  .donut-wrap {
    position: relative;
    width: 224px;
    height: 224px;
    flex-shrink: 0;
  }
  .donut-svg {
    transform: rotate(-90deg);
  }
  .donut-center {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .donut-total {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-ink);
  }
  .donut-label {
    font-size: 0.75rem;
    color: var(--color-ink-muted);
  }
  .pension-legend {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
    font-size: 0.875rem;
  }
  .pension-legend-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .pension-dot {
    width: 16px;
    height: 16px;
    border-radius: 9999px;
    flex-shrink: 0;
  }
  .pension-type {
    flex: 1;
    font-weight: 500;
    color: var(--color-ink);
  }
  .pension-amount {
    color: var(--color-ink-muted);
  }
  .pension-pct {
    color: var(--color-ink-muted);
    font-size: 0.75rem;
    width: 56px;
    text-align: right;
  }

  /* ── Infrastructure Stats ── */
  .infra-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 32px;
  }
  .stat-card {
    text-align: center;
    padding: 24px;
    border-radius: 10px;
  }
  .stat-green { background: var(--color-green-light); }
  .stat-blue { background: var(--color-blue-light); }
  .stat-neutral { background: var(--color-surface-cool); }

  .stat-number {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
  }
  .stat-number-green { color: var(--color-green); }
  .stat-number-blue { color: var(--color-blue); }
  .stat-number-neutral { color: var(--color-ink-muted); }

  .stat-label {
    margin-top: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .stat-label-green { color: var(--color-green); }
  .stat-label-blue { color: var(--color-blue); }
  .stat-label-neutral { color: var(--color-ink-muted); }

  .stat-pct {
    margin-top: 4px;
    font-size: 0.75rem;
  }
  .stat-pct-green { color: var(--color-green); opacity: 0.7; }
  .stat-pct-blue { color: var(--color-blue); opacity: 0.7; }
  .stat-pct-neutral { color: var(--color-ink-muted); opacity: 0.7; }

  /* ── Breakdown ── */
  .breakdown-box {
    background: var(--color-surface-cool);
    border-radius: 8px;
    padding: 20px;
  }
  .breakdown-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-bottom: 12px;
  }
  .breakdown-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  .breakdown-heading {
    font-weight: 500;
    color: var(--color-ink);
    margin-bottom: 4px;
    font-size: 0.875rem;
  }
  .breakdown-text {
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    line-height: 1.6;
  }

  /* ── Table ── */
  .table-wrap { overflow-x: auto; }
  .schemes-table {
    width: 100%;
    text-align: left;
    border-collapse: collapse;
  }
  .schemes-table th {
    padding-bottom: 12px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 2px solid var(--color-border-light);
  }
  .schemes-table td {
    padding: 16px 0;
    border-bottom: 1px solid var(--color-border-light);
  }
  .schemes-table tr:last-child td { border-bottom: 0; }

  .rank-dot {
    width: 32px;
    height: 32px;
    border-radius: 9999px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .rank-dot span {
    color: #fff;
    font-size: 0.875rem;
    font-weight: 700;
  }
  .scheme-name {
    font-weight: 500;
    color: var(--color-ink);
    font-size: 1rem;
  }
  .scheme-value {
    font-weight: 600;
    color: var(--color-ink);
    font-size: 1rem;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero-section { padding: 48px 0; }
    .hero-title { font-size: 2rem; }
    .content-section, .content-section-alt { padding: 32px 0; }
    .dashboard-card { padding: 20px; }
    .card-header { flex-direction: column; }
    .bar-values { display: none; }
    .pension-layout { flex-direction: column; }
    .infra-stats { grid-template-columns: 1fr; gap: 12px; }
    .stat-number { font-size: 1.75rem; }
    .breakdown-grid { grid-template-columns: 1fr; }
  }

  @media (min-width: 640px) {
    .card-header {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
    .card-subtext { margin-top: 0; }
  }

  @media (min-width: 768px) {
    .dashboard-card { padding: 32px; }
  }
</style>
