---
import Base from '../layouts/Base.astro';
---

<Base title="Coming Soon">
  <section class="coming-soon">
    <div class="container">
      <div class="content">
        <div class="icon-wrap">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <h1>Coming Soon</h1>
        <p>This page is under development. We're working on bringing you detailed information for every service, scheme, and resource on the portal.</p>
        <div class="links">
          <a href="/" class="link-primary">Back to Home</a>
          <a href="/services" class="link-secondary">Browse All Services</a>
          <a href="/dashboard" class="link-secondary">View Dashboard</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .coming-soon {
    padding: 120px 0 160px;
    text-align: center;
  }
  .content {
    max-width: 480px;
    margin: 0 auto;
  }
  .icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--color-surface-cool);
    margin-bottom: 24px;
    color: var(--color-ink-muted);
  }
  h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-bottom: 12px;
  }
  p {
    color: var(--color-ink-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 32px;
  }
  .links {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .link-primary {
    padding: 10px 24px;
    background: var(--color-ink);
    color: #fff;
    border-radius: 100px;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }
  .link-primary:hover { background: var(--color-red); color: #fff; }
  .link-secondary {
    padding: 10px 24px;
    border: 1px solid var(--color-border);
    color: var(--color-ink-light);
    border-radius: 100px;
    font-size: 0.88rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
  }
  .link-secondary:hover { border-color: var(--color-red); color: var(--color-red); }
</style>
