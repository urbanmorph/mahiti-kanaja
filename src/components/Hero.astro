---
// Hero.astro — Dark hero section matching original mockup spacing
---

<section class="hero-section relative overflow-hidden">
  <!-- Radial glow effects -->
  <div class="absolute -top-1/2 -right-[20%] w-[600px] h-[600px] pointer-events-none" style="background: radial-gradient(circle, rgba(196,30,58,0.15) 0%, transparent 70%);"></div>
  <div class="absolute -bottom-[30%] -left-[10%] w-[500px] h-[500px] pointer-events-none" style="background: radial-gradient(circle, rgba(255,215,0,0.08) 0%, transparent 70%);"></div>

  <!-- Geometric pattern overlay -->
  <div class="hero-pattern absolute inset-0 pointer-events-none" aria-hidden="true"></div>

  <div class="container relative z-10">
    <div class="hero-content">
      <!-- Trust badge pill -->
      <div class="trust-badge fade-up">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
        <span data-en="No login required — all information is public" data-kn="ಲಾಗಿನ್ ಅಗತ್ಯವಿಲ್ಲ — ಎಲ್ಲಾ ಮಾಹಿತಿ ಸಾರ್ವಜನಿಕ">No login required — all information is public</span>
      </div>

      <!-- Heading -->
      <h1 class="fade-up" data-en="Know how your public funds are being spent" data-kn="ನಿಮ್ಮ ಸಾರ್ವಜನಿಕ ನಿಧಿ ಹೇಗೆ ಖರ್ಚಾಗುತ್ತಿದೆ ಎಂದು ತಿಳಿಯಿರಿ">Know how your <span>public funds</span> are being spent</h1>

      <!-- Subtext -->
      <p class="hero-sub fade-up" data-en="A single window to track government expenditure, access citizen services, and hold your representatives accountable — from village to state level." data-kn="ಸರ್ಕಾರಿ ವೆಚ್ಚವನ್ನು ಟ್ರ್ಯಾಕ್ ಮಾಡಲು, ನಾಗರಿಕ ಸೇವೆಗಳನ್ನು ಪಡೆಯಲು ಮತ್ತು ನಿಮ್ಮ ಪ್ರತಿನಿಧಿಗಳನ್ನು ಹೊಣೆಗಾರರನ್ನಾಗಿ ಮಾಡಲು ಒಂದೇ ಕಿಟಕಿ — ಗ್ರಾಮದಿಂದ ರಾಜ್ಯ ಮಟ್ಟದವರೆಗೆ.">A single window to track government expenditure, access citizen services, and hold your representatives accountable — from village to state level.</p>

      <!-- Stats row -->
      <div class="stats-row fade-up">
        <div class="stat-item">
          <div class="stat-num">450<span class="accent">+</span></div>
          <div class="stat-label" data-en="Services" data-kn="ಸೇವೆಗಳು">Services</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">30<span class="accent">+</span></div>
          <div class="stat-label" data-en="Departments" data-kn="ಇಲಾಖೆಗಳು">Departments</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">19M<span class="accent">+</span></div>
          <div class="stat-label" data-en="Citizens Served" data-kn="ನಾಗರಿಕರಿಗೆ ಸೇವೆ">Citizens Served</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    background: linear-gradient(135deg, var(--color-ink) 0%, #2D2D48 50%, #1E1E38 100%);
    padding: 72px 0 64px;
  }

  .hero-pattern {
    opacity: 0.03;
    background-image:
      linear-gradient(30deg, #fff 12%, transparent 12.5%, transparent 87%, #fff 87.5%, #fff),
      linear-gradient(150deg, #fff 12%, transparent 12.5%, transparent 87%, #fff 87.5%, #fff),
      linear-gradient(30deg, #fff 12%, transparent 12.5%, transparent 87%, #fff 87.5%, #fff),
      linear-gradient(150deg, #fff 12%, transparent 12.5%, transparent 87%, #fff 87.5%, #fff),
      linear-gradient(60deg, rgba(255,255,255,0.6) 25%, transparent 25.5%, transparent 75%, rgba(255,255,255,0.6) 75%),
      linear-gradient(60deg, rgba(255,255,255,0.6) 25%, transparent 25.5%, transparent 75%, rgba(255,255,255,0.6) 75%);
    background-size: 40px 70px;
    background-position: 0 0, 0 0, 20px 35px, 20px 35px, 0 0, 20px 35px;
  }

  .hero-content { max-width: 680px; }

  .trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    padding: 8px 16px;
    border-radius: 100px;
    margin-bottom: 40px;
  }
  .trust-badge svg { width: 16px; height: 16px; stroke: var(--color-green); flex-shrink: 0; }
  .trust-badge span { font-size: 0.82rem; color: rgba(255,255,255,0.8); }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 600;
    color: #fff;
    line-height: 1.2;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }
  h1 span { color: var(--color-gold); }

  .hero-sub {
    color: rgba(255,255,255,0.7);
    font-size: 1.05rem;
    max-width: 500px;
    margin-bottom: 32px;
    line-height: 1.7;
  }

  .stats-row { display: flex; gap: 48px; }
  .stat-item { text-align: left; }
  .stat-num {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 700;
    color: #fff;
    line-height: 1;
    margin-bottom: 4px;
  }
  .stat-num .accent { color: var(--color-gold); }
  .stat-label {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
  }
  .stat-item::after {
    content: '';
    display: block;
    width: 32px;
    height: 2px;
    background: var(--color-gold);
    margin-top: 10px;
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .hero-section { padding: 48px 0 40px; }
    h1 { font-size: 1.6rem; }
    .stats-row { gap: 24px; flex-wrap: wrap; }
    .stat-num { font-size: 1.6rem; }
  }
</style>
