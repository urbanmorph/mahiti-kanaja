---
// TopBar.astro — Dark utility bar
---

<div class="top-bar">
  <div class="container">
    <div class="top-bar-left">
      <span>Government of Karnataka</span>
      <a href="/coming-soon">RTI Disclosure</a>
      <a href="/coming-soon">Sitemap</a>
    </div>
    <div class="top-bar-right">
      <div class="lang-toggle">
        <button class="active" data-lang="en">English</button>
        <button data-lang="kn">ಕನ್ನಡ</button>
      </div>
      <div class="a11y-controls">
        <button class="a11y-btn" id="font-decrease" title="Decrease font size">A-</button>
        <button class="a11y-btn" id="font-increase" title="Increase font size">A+</button>
        <button class="a11y-btn" id="contrast-toggle" title="High contrast">◐</button>
      </div>
      <div class="helpline">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        <span>080-22258338</span>
      </div>
    </div>
  </div>
</div>

<style>
  .top-bar {
    background: #1A1A2E;
    color: rgba(255,255,255,0.85);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    position: relative;
    z-index: 100;
  }
  .top-bar .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 38px;
    gap: 16px;
  }
  .top-bar-left, .top-bar-right { display: flex; align-items: center; gap: 16px; }
  .top-bar a { color: rgba(255,255,255,0.85); font-size: 0.8rem; text-decoration: none; }
  .top-bar a:hover { color: var(--color-gold); }

  .lang-toggle {
    display: flex;
    background: rgba(255,255,255,0.1);
    border-radius: 4px;
    overflow: hidden;
  }
  .lang-toggle button {
    background: none; border: none;
    color: rgba(255,255,255,0.6);
    padding: 3px 10px; font-size: 0.75rem;
    cursor: pointer; font-family: var(--font-body); transition: all 0.2s;
  }
  .lang-toggle button.active {
    background: rgba(255,255,255,0.18);
    color: #fff;
  }

  .a11y-controls { display: flex; gap: 4px; }
  .a11y-btn {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.7);
    width: 26px; height: 26px;
    border-radius: 4px; cursor: pointer;
    font-size: 0.7rem; font-family: var(--font-body); font-weight: 600;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.2s;
  }
  .a11y-btn:hover { background: rgba(255,255,255,0.15); color: #fff; }

  .helpline { display: flex; align-items: center; gap: 6px; }
  .helpline svg { width: 13px; height: 13px; opacity: 0.7; }

  @media (max-width: 768px) {
    .top-bar .container { font-size: 0.72rem; }
    .top-bar-left { display: none; }
  }
</style>
