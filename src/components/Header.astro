---
// Header.astro — Sticky header with Fuse.js search
import { buildSearchItems } from '../lib/searchData.js';

interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props;

const navLinks = [
  { label: 'Services', href: '/services', key: 'services' },
  { label: 'Dashboard', href: '/dashboard', key: 'dashboard' },
  { label: 'Explore', href: '/explore/by-department', key: 'explore' },
  { label: 'Data', href: '/data', key: 'data' },
];

const searchItems = buildSearchItems();
---

<header class="header">
  <div class="container">
    <a href="/" class="header-brand">
      <div class="emblem">
        <svg width="24" height="24" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
      </div>
      <div class="brand-text">
        <div class="kn">ಮಾಹಿತಿ ಕಣಜ</div>
        <div class="en">Mahiti Kanaja</div>
      </div>
    </a>

    <div class="search-wrap">
      <div class="search-bar">
        <input type="text" id="search-input" placeholder="Search for any government service, scheme, or data..." autocomplete="off">
        <button aria-label="Search" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </button>
      </div>
      <div class="search-meta">Powered by fuzzy search</div>

      <!-- Search results dropdown -->
      <div class="search-dropdown" id="search-dropdown">
        <div id="search-results"></div>
        <div class="search-empty" id="search-empty">
          No results found. Try a different keyword.
        </div>
      </div>
    </div>

    <nav class="header-nav">
      {navLinks.map((link) => (
        <a href={link.href} class:list={{ active: currentPage === link.key }}>
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<!-- Inject search index as JSON for client-side Fuse.js -->
<script is:inline define:vars={{ searchItems }}>
  window.__SEARCH_ITEMS__ = searchItems;
</script>

<script>
  import Fuse from 'fuse.js';

  document.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById('search-input') as HTMLInputElement;
    const dropdown = document.getElementById('search-dropdown') as HTMLElement;
    const resultsEl = document.getElementById('search-results') as HTMLElement;
    const emptyEl = document.getElementById('search-empty') as HTMLElement;

    if (!input || !dropdown || !resultsEl || !emptyEl) return;

    const items = (window as any).__SEARCH_ITEMS__ || [];

    const fuse = new Fuse(items, {
      keys: [
        { name: 'tags', weight: 2.0 },
        { name: 'nameEn', weight: 1.5 },
        { name: 'nameKn', weight: 1.5 },
        { name: 'descEn', weight: 0.8 },
        { name: 'descKn', weight: 0.8 },
      ],
      threshold: 0.4,
      distance: 100,
      includeScore: true,
      minMatchCharLength: 2,
    });

    // Detect Kannada input
    function isKannada(text: string): boolean {
      return /[\u0C80-\u0CFF]/.test(text);
    }

    // Type badge colors
    const typeBadge: Record<string, { label: string, color: string, bg: string }> = {
      service: { label: 'Service', color: '#C41E3A', bg: '#F8E8EB' },
      department: { label: 'Department', color: '#2563EB', bg: '#EFF6FF' },
      scheme: { label: 'Scheme', color: '#0D9F6E', bg: '#ECFDF5' },
    };

    let debounceTimer: number;

    input.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = window.setTimeout(() => {
        const query = input.value.trim();

        if (query.length < 2) {
          dropdown.classList.remove('open');
          return;
        }

        const results = fuse.search(query, { limit: 8 });
        const kn = isKannada(query);

        if (results.length === 0) {
          resultsEl.innerHTML = '';
          emptyEl.style.display = 'block';
          dropdown.classList.add('open');
          return;
        }

        emptyEl.style.display = 'none';

        resultsEl.innerHTML = results.map(({ item }) => {
          const badge = typeBadge[item.type] || typeBadge.service;
          const name = kn ? item.nameKn : item.nameEn;
          const desc = kn ? item.descKn : item.descEn;

          return `<a href="${item.url}" class="search-result">
            <div class="result-top">
              <span class="result-name">${name}</span>
              <span class="result-badge" style="color:${badge.color};background:${badge.bg}">${badge.label}</span>
            </div>
            <div class="result-desc">${desc}</div>
          </a>`;
        }).join('');

        dropdown.classList.add('open');
      }, 150);
    });

    // Close dropdown on click outside
    document.addEventListener('click', (e) => {
      if (!(e.target as HTMLElement).closest('.search-wrap')) {
        dropdown.classList.remove('open');
      }
    });

    // Close on Escape
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        dropdown.classList.remove('open');
        input.blur();
      }
    });

    // Reopen on focus if there's a query
    input.addEventListener('focus', () => {
      if (input.value.trim().length >= 2 && resultsEl.innerHTML) {
        dropdown.classList.add('open');
      }
    });
  });
</script>

<style>
  .header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 90;
    box-shadow: 0 1px 8px rgba(26,26,46,0.04);
  }
  .header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    gap: 24px;
  }

  .header-brand {
    display: flex; align-items: center; gap: 14px; flex-shrink: 0;
    text-decoration: none; color: var(--color-ink);
  }
  .header-brand:hover { color: var(--color-ink); }
  .emblem {
    width: 46px; height: 46px;
    background: var(--color-red); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; position: relative; overflow: hidden;
  }
  .emblem::after {
    content: ''; position: absolute; inset: 3px;
    border: 1.5px solid rgba(255,255,255,0.3); border-radius: 50%;
  }
  .emblem :global(svg) { width: 24px; height: 24px; fill: white; }
  .brand-text { line-height: 1.2; }
  .brand-text .kn { font-size: 1rem; font-weight: 600; color: var(--color-red); letter-spacing: -0.01em; }
  .brand-text .en { font-size: 0.72rem; color: var(--color-ink-muted); font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; }

  /* Search */
  .search-wrap { flex: 1; max-width: 520px; position: relative; }

  .search-bar { position: relative; }
  .search-bar input {
    width: 100%; height: 44px;
    border: 2px solid var(--color-border); border-radius: 22px;
    padding: 0 44px 0 20px;
    font-family: var(--font-body); font-size: 0.9rem; color: var(--color-ink);
    background: var(--color-surface-cool);
    transition: all 0.25s cubic-bezier(0.22, 1, 0.36, 1);
    outline: none;
  }
  .search-bar input::placeholder { color: var(--color-ink-muted); }
  .search-bar input:focus {
    border-color: var(--color-red);
    background: var(--color-surface);
    box-shadow: 0 0 0 4px var(--color-red-light);
  }
  .search-bar button {
    position: absolute; right: 4px; top: 4px;
    width: 36px; height: 36px;
    background: var(--color-red); border: none; border-radius: 50%;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: background 0.2s;
  }
  .search-bar button:hover { background: var(--color-red-dark); }

  .search-meta {
    font-size: 0.65rem;
    color: var(--color-ink-muted);
    text-align: right;
    margin-top: 4px;
    padding-right: 8px;
    letter-spacing: 0.02em;
    opacity: 0.7;
  }

  /* Dropdown */
  .search-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    left: 0; right: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: 0 12px 40px rgba(26,26,46,0.15), 0 4px 12px rgba(26,26,46,0.08);
    overflow: hidden;
    z-index: 100;
    max-height: 420px;
    overflow-y: auto;
  }
  .search-dropdown.open { display: block; }

  .search-empty {
    display: none;
    padding: 24px;
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-ink-muted);
  }

  /* Results — styled via :global since innerHTML */
  .search-dropdown :global(.search-result) {
    display: block;
    padding: 12px 16px;
    text-decoration: none;
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-border-light);
    transition: background 0.15s;
  }
  .search-dropdown :global(.search-result:last-child) { border-bottom: none; }
  .search-dropdown :global(.search-result:hover) { background: var(--color-surface-cool); }

  .search-dropdown :global(.result-top) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 2px;
  }
  .search-dropdown :global(.result-name) {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-ink);
  }
  .search-dropdown :global(.result-badge) {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 8px;
    border-radius: 100px;
    flex-shrink: 0;
  }
  .search-dropdown :global(.result-desc) {
    font-size: 0.78rem;
    color: var(--color-ink-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .header-nav { display: flex; gap: 6px; flex-shrink: 0; }
  .header-nav a {
    font-size: 0.82rem; font-weight: 500; color: var(--color-ink-light);
    padding: 6px 12px; border-radius: 6px; transition: all 0.2s;
    text-decoration: none;
  }
  .header-nav a:hover, .header-nav a.active { color: var(--color-red); background: var(--color-red-light); }

  @media (max-width: 768px) {
    .header .container { height: 60px; }
    .header-nav { display: none; }
    .search-wrap { max-width: none; }
    .search-meta { display: none; }
  }
</style>
